# Vertalis's own WordPress backend (same one the main vertalispeptides.com
# storefront already uses via lib/wc-server.ts). Set these as Environment
# Variables in the Vercel project (Production + Preview) dashboard — do NOT
# put real values in this file. Copy it to `.env` (gitignored) if you need
# real values locally for `vercel dev`.

WC_URL=https://cms.vertalispeptides.com
WC_USER=your-wp-admin-username
WC_APP_PASSWORD=your-wp-application-password
